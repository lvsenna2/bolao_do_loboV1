}

model FootballApiRequestLog {
  id              String   @id @default(uuid()) @db.Uuid
  endpoint        String   @db.VarChar(100)
  params          Json?
  statusCode      Int?     @map("status_code")
  ok              Boolean
  durationMs      Int      @map("duration_ms")
  dailyLimit      Int?     @map("daily_limit")
  dailyRemaining  Int?     @map("daily_remaining")
  minuteLimit     Int?     @map("minute_limit")
  minuteRemaining Int?     @map("minute_remaining")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([endpoint, createdAt])
  @@index([ok, createdAt])
  @@map("football_api_request_logs")
}

model FootballSyncState {
  key                     String    @id @db.VarChar(80)
  status                  String    @default("IDLE") @db.VarChar(20)
  lastStartedAt           DateTime? @map("last_started_at")
  lastFinishedAt          DateTime? @map("last_finished_at")
  lastSuccessAt           DateTime? @map("last_success_at")
  nextRunAt               DateTime? @map("next_run_at")
  lastError               String?   @map("last_error")
  callsUsed               Int       @default(0) @map("calls_used")
  dailyRemaining          Int?      @map("daily_remaining")
  trackedMatches          Int       @default(0) @map("tracked_matches")
  liveMatches             Int       @default(0) @map("live_matches")
  pendingLineups          Int       @default(0) @map("pending_lineups")
  pendingFinalDetails     Int       @default(0) @map("pending_final_details")
  updatedAt               DateTime  @updatedAt @map("updated_at")

