generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ORGANIZER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING_EMAIL
  ACTIVE
  BLOCKED
  DELETED
}

enum LeagueVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum LeagueStatus {
  DRAFT
  OPEN
  ACTIVE
  FINISHED
  ARCHIVED
}

enum LeagueRole {
  OWNER
  MODERATOR
  MEMBER
}

enum MemberStatus {
  PENDING_PAYMENT
  ACTIVE
  BLOCKED
  LEFT
}

enum ChampionshipStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SeasonStatus {
  SCHEDULED
  ACTIVE
  FINISHED
  ARCHIVED
}

enum RoundStatus {
  SCHEDULED
  OPEN
  LIVE
  FINISHED
  CLOSED
  ARCHIVED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  SUSPENDED
  CANCELLED
}

enum LineupPlayerRole {
  STARTER
  SUBSTITUTE
}

enum Prediction {
  HOME
  DRAW
  AWAY
}

enum RankingScope {
  GLOBAL
  LEAGUE
  ROUND
  MONTHLY
  HISTORICAL
}

enum PaymentGateway {
  MERCADO_PAGO
  ASAAS
  STRIPE
  PAGSEGURO
  PIX
  MANUAL
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  REFUNDED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  SYSTEM
  MATCH
  PAYMENT
  RANKING
  XP
}

enum BadgeRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model User {
  id              String        @id @default(uuid()) @db.Uuid
  name            String        @db.VarChar(120)
  firstName       String?       @map("first_name") @db.VarChar(80)
  lastName        String?       @map("last_name") @db.VarChar(80)
  username        String        @unique @db.VarChar(40)
  email           String        @unique @db.VarChar(150)
  emailVerified   DateTime?     @map("email_verified")
  passwordHash    String?       @map("password_hash")
  birthDate       DateTime?     @map("birth_date")
  avatarUrl       String?       @map("avatar_url")
  role            UserRole      @default(USER)
  status          AccountStatus @default(PENDING_EMAIL)
  xp              Int           @default(0)
  level           Int           @default(1)
  locale          String        @default("pt-BR") @db.VarChar(12)
  theme           String        @default("system") @db.VarChar(20)
  termsAcceptedAt DateTime?     @map("terms_accepted_at")
  lastLoginAt     DateTime?     @map("last_login_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  accounts               Account[]
  sessions               Session[]
  ownedLeagues           League[]              @relation("LeagueOwner")
  memberships            LeagueMember[]
  guesses                Guess[]
  scores                 Score[]
  rankings               Ranking[]
  rankingAdjustments     RankingAdjustment[]   @relation("RankingAdjustmentUser")
  rankingAdjustmentsMade RankingAdjustment[]   @relation("RankingAdjustmentAdmin")
  payments               Payment[]
  notifications          Notification[]
  achievements           Achievement[]
  xpEvents               XpEvent[]             @relation("XpEventUser")
  xpEventsGranted        XpEvent[]             @relation("XpEventAdmin")
  xpStreak               UserStreak?
  missionProgress        UserMissionProgress[]
  auditLogs              AuditLog[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model League {
  id             String           @id @default(uuid()) @db.Uuid
  ownerId        String           @map("owner_id") @db.Uuid
  championshipId String           @map("championship_id") @db.Uuid
  name           String           @db.VarChar(120)
  description    String?
  imageUrl       String?          @map("image_url")
  visibility     LeagueVisibility @default(PRIVATE)
  status         LeagueStatus     @default(DRAFT)
  entryFee       Decimal          @default(0) @map("entry_fee") @db.Decimal(10, 2)
  xpEnabled      Boolean          @default(true) @map("xp_enabled")
  maxMembers     Int?             @map("max_members")
  inviteCode     String?          @unique @map("invite_code") @db.VarChar(32)
  rules          Json?
  prizeRules     Json?            @map("prize_rules")
  startsAt       DateTime?        @map("starts_at")
  endsAt         DateTime?        @map("ends_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  owner              User                @relation("LeagueOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  championship       Championship        @relation(fields: [championshipId], references: [id], onDelete: Restrict)
  members            LeagueMember[]
  payments           Payment[]
  rankings           Ranking[]
  rounds             Round[]
  guesses            Guess[]
  scores             Score[]
  rankingAdjustments RankingAdjustment[]
  xpEvents           XpEvent[]

  @@index([ownerId])
  @@index([championshipId])
  @@index([visibility])
  @@index([status])
  @@index([createdAt])
  @@map("leagues")
}

model LeagueMember {
  id        String       @id @default(uuid()) @db.Uuid
  leagueId  String       @map("league_id") @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  role      LeagueRole   @default(MEMBER)
  status    MemberStatus @default(PENDING_PAYMENT)
  joinedAt  DateTime     @default(now()) @map("joined_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  leftAt    DateTime?    @map("left_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([leagueId, userId])
  @@index([userId])
  @@index([status])
  @@map("league_members")
}

model Championship {
  id           String             @id @default(uuid()) @db.Uuid
  name         String             @db.VarChar(120)
  country      String             @db.VarChar(80)
  logo         String?
  provider     String?            @db.VarChar(40)
  apiId        Int?               @map("api_id")
  status       ChampionshipStatus @default(ACTIVE)
  description  String?
  primaryColor String?            @map("primary_color") @db.VarChar(20)
  coverage     Json?
  coverageSyncedAt DateTime?      @map("coverage_synced_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  deletedAt    DateTime?          @map("deleted_at")

  leagues League[]
  seasons Season[]

  @@unique([provider, apiId])
  @@index([country])
  @@index([status])
  @@map("championships")
}

model Season {
  id             String       @id @default(uuid()) @db.Uuid
  championshipId String       @map("championship_id") @db.Uuid
  year           Int
  name           String?      @db.VarChar(80)
  status         SeasonStatus @default(SCHEDULED)
  startsAt       DateTime?    @map("starts_at")
  endsAt         DateTime?    @map("ends_at")
  coverage       Json?
  coverageSyncedAt DateTime?  @map("coverage_synced_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  championship Championship          @relation(fields: [championshipId], references: [id], onDelete: Restrict)
  rounds       Round[]
  rankings     Ranking[]
  standings    CompetitionStanding[]
  xpEvents     XpEvent[]

  @@unique([championshipId, year])
  @@index([status])
  @@map("seasons")
}

model Round {
  id          String      @id @default(uuid()) @db.Uuid
  seasonId    String      @map("season_id") @db.Uuid
  leagueId    String?     @map("league_id") @db.Uuid
  number      Int
  name        String?     @db.VarChar(80)
  description String?
  startsAt    DateTime    @map("starts_at")
  endsAt      DateTime    @map("ends_at")
  status      RoundStatus @default(SCHEDULED)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  season   Season    @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  league   League?   @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  matches  Match[]
  rankings Ranking[]

  @@unique([leagueId, seasonId, number])
  @@index([leagueId])
  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
  @@map("rounds")
}

model Team {
  id        String   @id @default(uuid()) @db.Uuid
  apiId     Int?     @map("api_id")
  name      String   @db.VarChar(120)
  shortName String?  @map("short_name") @db.VarChar(30)
  country   String   @db.VarChar(80)
  logo      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  homeMatches Match[]               @relation("HomeTeam")
  awayMatches Match[]               @relation("AwayTeam")
  standings   CompetitionStanding[]
  lineups     MatchLineup[]
  matchEvents MatchEvent[]
  matchStatistics MatchStatistic[]
  playerStatistics MatchPlayerStatistic[]

  @@unique([apiId])
  @@index([name])
  @@index([country])
  @@map("teams")
}

model Match {
  id            String      @id @default(uuid()) @db.Uuid
  apiId         Int?        @unique @map("api_id")
  roundId       String      @map("round_id") @db.Uuid
  homeTeamId    String      @map("home_team_id") @db.Uuid
  awayTeamId    String      @map("away_team_id") @db.Uuid
  kickoff       DateTime
  homeScore     Int?        @map("home_score")
  awayScore     Int?        @map("away_score")
  stadium       String?     @db.VarChar(160)
  city          String?     @db.VarChar(100)
  country       String?     @db.VarChar(80)
  referee       String?     @db.VarChar(120)
  broadcast     String?     @db.VarChar(120)
  status        MatchStatus @default(SCHEDULED)
  apiStatus     String?     @map("api_status") @db.VarChar(20)
  statusLong    String?     @map("status_long") @db.VarChar(80)
  elapsed       Int?
  extraTime     Int?        @map("extra_time")
  halftimeHome  Int?        @map("halftime_home")
  halftimeAway  Int?        @map("halftime_away")
  secondHalfHome Int?       @map("second_half_home")
  secondHalfAway Int?       @map("second_half_away")
  extraTimeHome Int?        @map("extra_time_home")
  extraTimeAway Int?        @map("extra_time_away")
  penaltyHome   Int?        @map("penalty_home")
  penaltyAway   Int?        @map("penalty_away")
  footballVenueId String?   @map("football_venue_id") @db.Uuid
  homologatedAt DateTime?   @map("homologated_at")
  lastSyncedAt  DateTime?   @map("last_synced_at")
  liveSyncedAt  DateTime?   @map("live_synced_at")
  lineupsSyncedAt DateTime? @map("lineups_synced_at")
  eventsSyncedAt DateTime?  @map("events_synced_at")
  statisticsSyncedAt DateTime? @map("statistics_synced_at")
  playersSyncedAt DateTime? @map("players_synced_at")
  historySyncedAt DateTime? @map("history_synced_at")
  fullySyncedAt DateTime?   @map("fully_synced_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  round    Round     @relation(fields: [roundId], references: [id], onDelete: Restrict)
  homeTeam Team      @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam Team      @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  footballVenue FootballVenue? @relation(fields: [footballVenueId], references: [id], onDelete: SetNull)
  guesses  Guess[]
  scores   Score[]
  xpEvents XpEvent[]
  lineups MatchLineup[]
  events MatchEvent[]
  statistics MatchStatistic[]
  playerStatistics MatchPlayerStatistic[]
  insight MatchInsight?

  @@index([roundId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([kickoff])
  @@index([status])
  @@index([apiStatus])
  @@index([lastSyncedAt])
  @@index([fullySyncedAt])
  @@index([footballVenueId])
  @@map("matches")
}

model FootballVenue {
  id         String   @id @default(uuid()) @db.Uuid
  externalId Int      @unique @map("external_id")
  name       String   @db.VarChar(160)
  address    String?  @db.VarChar(200)
  city       String?  @db.VarChar(100)
  country    String?  @db.VarChar(80)
  capacity   Int?
  surface    String?  @db.VarChar(80)
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  matches Match[]

  @@index([city])
  @@map("football_venues")
}

model FootballPlayer {
  id         String   @id @default(uuid()) @db.Uuid
  externalId Int      @unique @map("external_id")
  name       String   @db.VarChar(140)
  firstName  String?  @map("first_name") @db.VarChar(100)
  lastName   String?  @map("last_name") @db.VarChar(100)
  position   String?  @db.VarChar(40)
  photoUrl   String?  @map("photo_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  lineupEntries MatchLineupPlayer[]
  events        MatchEvent[] @relation("MatchEventPlayer")
  assistedEvents MatchEvent[] @relation("MatchEventAssist")
  matchStatistics MatchPlayerStatistic[]

  @@index([name])
  @@map("football_players")
}

model MatchLineup {
  id              String   @id @default(uuid()) @db.Uuid
  matchId         String   @map("match_id") @db.Uuid
  teamId          String   @map("team_id") @db.Uuid
  formation       String?  @db.VarChar(30)
  coachExternalId Int?     @map("coach_external_id")
  coachName       String?  @map("coach_name") @db.VarChar(140)
  coachPhotoUrl   String?  @map("coach_photo_url")
  complete        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  match   Match               @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team    Team                @relation(fields: [teamId], references: [id], onDelete: Restrict)
  players MatchLineupPlayer[]

  @@unique([matchId, teamId])
  @@index([teamId])
  @@map("match_lineups")
}

model MatchLineupPlayer {
  id          String           @id @default(uuid()) @db.Uuid
  lineupId    String           @map("lineup_id") @db.Uuid
  playerId    String           @map("player_id") @db.Uuid
  role        LineupPlayerRole
  shirtNumber Int?             @map("shirt_number")
  position    String?          @db.VarChar(20)
  grid        String?          @db.VarChar(20)
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  lineup MatchLineup   @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  player FootballPlayer @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([lineupId, playerId])
  @@index([playerId])
  @@map("match_lineup_players")
}

model MatchEvent {
  id             String   @id @default(uuid()) @db.Uuid
  matchId        String   @map("match_id") @db.Uuid
  externalKey    String   @unique @map("external_key") @db.VarChar(180)
  elapsed        Int
  extra          Int?
  teamId         String?  @map("team_id") @db.Uuid
  playerId       String?  @map("player_id") @db.Uuid
  assistPlayerId String?  @map("assist_player_id") @db.Uuid
  type           String   @db.VarChar(60)
  detail         String?  @db.VarChar(120)
  comments       String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  match        Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team         Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player       FootballPlayer? @relation("MatchEventPlayer", fields: [playerId], references: [id], onDelete: SetNull)
  assistPlayer FootballPlayer? @relation("MatchEventAssist", fields: [assistPlayerId], references: [id], onDelete: SetNull)

  @@index([matchId, elapsed])
  @@index([teamId])
  @@map("match_events")
}

model MatchStatistic {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @map("match_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  period    String   @default("FULL_TIME") @db.VarChar(20)
  type      String   @db.VarChar(100)
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@unique([matchId, teamId, period, type])
  @@index([teamId])
  @@map("match_statistics")
}

model MatchPlayerStatistic {
  id         String   @id @default(uuid()) @db.Uuid
  matchId    String   @map("match_id") @db.Uuid
  teamId     String   @map("team_id") @db.Uuid
  playerId   String   @map("player_id") @db.Uuid
  statistics Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  match  Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team   Team           @relation(fields: [teamId], references: [id], onDelete: Restrict)
  player FootballPlayer @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([matchId, teamId, playerId])
  @@index([playerId])
  @@map("match_player_statistics")
}

model MatchInsight {
  id              String   @id @default(uuid()) @db.Uuid
  matchId         String   @unique @map("match_id") @db.Uuid
  homeRecent      Json?    @map("home_recent")
  awayRecent      Json?    @map("away_recent")
  homeSeasonStats Json?    @map("home_season_stats")
  awaySeasonStats Json?    @map("away_season_stats")
  headToHead      Json?    @map("head_to_head")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_insights")
}

model Guess {
  id             String     @id @default(uuid()) @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  leagueId       String?    @map("league_id") @db.Uuid
  matchId        String     @map("match_id") @db.Uuid
  prediction     Prediction
  homePrediction Int?       @map("home_prediction")
  awayPrediction Int?       @map("away_prediction")
  joker          Boolean    @default(false)
  notes          String?    @db.VarChar(240)
  submittedAt    DateTime   @default(now()) @map("submitted_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  league   League?   @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  match    Match     @relation(fields: [matchId], references: [id], onDelete: Restrict)
  score    Score?
  xpEvents XpEvent[]

  @@unique([userId, leagueId, matchId])
  @@index([leagueId])
  @@index([matchId])
  @@index([submittedAt])
  @@index([joker])
  @@map("guesses")
}

model Score {
  id           String   @id @default(uuid()) @db.Uuid
  guessId      String   @unique @map("guess_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  matchId      String   @map("match_id") @db.Uuid
  leagueId     String?  @map("league_id") @db.Uuid
  basePoints   Int      @default(0) @map("base_points")
  bonusPoints  Int      @default(0) @map("bonus_points")
  totalPoints  Int      @default(0) @map("total_points")
  winnerHit    Boolean  @default(false) @map("winner_hit")
  exactScore   Boolean  @default(false) @map("exact_score")
  jokerApplied Boolean  @default(false) @map("joker_applied")
  calculatedAt DateTime @default(now()) @map("calculated_at")

  guess  Guess   @relation(fields: [guessId], references: [id], onDelete: Restrict)
  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  match  Match   @relation(fields: [matchId], references: [id], onDelete: Restrict)
  league League? @relation(fields: [leagueId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([matchId])
  @@index([leagueId])
  @@index([totalPoints])
  @@map("scores")
}

model Ranking {
  id                   String       @id @default(uuid()) @db.Uuid
  scope                RankingScope @default(LEAGUE)
  leagueId             String?      @map("league_id") @db.Uuid
  seasonId             String?      @map("season_id") @db.Uuid
  roundId              String?      @map("round_id") @db.Uuid
  userId               String       @map("user_id") @db.Uuid
  position             Int?
  points               Int          @default(0)
  exactScores          Int          @default(0) @map("exact_scores")
  wins                 Int          @default(0)
  losses               Int          @default(0)
  hits                 Int          @default(0)
  currentStreak        Int          @default(0) @map("current_streak")
  averageSubmitSeconds Int?         @map("average_submit_seconds")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  league League? @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  round  Round?  @relation(fields: [roundId], references: [id], onDelete: Restrict)
  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([scope, leagueId, seasonId, roundId, userId])
  @@index([leagueId, points(sort: Desc), exactScores(sort: Desc), hits(sort: Desc)])
  @@index([userId])
  @@index([scope])
  @@map("rankings")
}

model RankingAdjustment {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  adminId     String   @map("admin_id") @db.Uuid
  pointsDelta Int      @map("points_delta")
  reason      String   @db.VarChar(240)
  createdAt   DateTime @default(now()) @map("created_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  user   User   @relation("RankingAdjustmentUser", fields: [userId], references: [id], onDelete: Restrict)
  admin  User   @relation("RankingAdjustmentAdmin", fields: [adminId], references: [id], onDelete: Restrict)

  @@index([leagueId, userId])
  @@index([adminId])
  @@index([createdAt])
  @@map("ranking_adjustments")
}

model XpLevel {
  id              String   @id @default(uuid()) @db.Uuid
  key             String   @unique @db.VarChar(80)
  name            String   @db.VarChar(80)
  medal           String   @db.VarChar(20)
  color           String   @db.VarChar(20)
  minXp           Int      @map("min_xp")
  maxXp           Int?     @map("max_xp")
  discountPercent Int      @default(0) @map("discount_percent")
  benefits        Json?
  active          Boolean  @default(true)
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([active, minXp])
  @@index([sortOrder])
  @@map("xp_levels")
}

model XpTypeConfig {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(80)
  label       String   @db.VarChar(120)
  description String?
  amount      Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("xp_type_configs")
}

model XpEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  adminId   String?  @map("admin_id") @db.Uuid
  guessId   String?  @map("guess_id") @db.Uuid
  matchId   String?  @map("match_id") @db.Uuid
  leagueId  String?  @map("league_id") @db.Uuid
  seasonId  String?  @map("season_id") @db.Uuid
  type      String   @db.VarChar(80)
  amount    Int
  uniqueKey String   @unique @map("unique_key") @db.VarChar(180)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation("XpEventUser", fields: [userId], references: [id], onDelete: Cascade)
  admin  User?   @relation("XpEventAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  guess  Guess?  @relation(fields: [guessId], references: [id], onDelete: SetNull)
  match  Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)
  league League? @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([leagueId, createdAt])
  @@index([seasonId, createdAt])
  @@index([type])
  @@map("xp_events")
}

model UserStreak {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @map("user_id") @db.Uuid
  currentCount          Int       @default(0) @map("current_count")
  longestCount          Int       @default(0) @map("longest_count")
  lastParticipationDate DateTime? @map("last_participation_date")
  awardedMilestones     Json?     @map("awarded_milestones")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model Mission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(80)
  title       String   @db.VarChar(140)
  description String
  type        String   @db.VarChar(80)
  target      Int
  xpReward    Int      @map("xp_reward")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  progress UserMissionProgress[]

  @@index([active, startsAt, endsAt])
  @@map("missions")
}

model UserMissionProgress {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  missionId       String    @map("mission_id") @db.Uuid
  progress        Int       @default(0)
  completedAt     DateTime? @map("completed_at")
  rewardClaimedAt DateTime? @map("reward_claimed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@index([missionId])
  @@map("user_mission_progress")
}

model Payment {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  leagueId      String         @map("league_id") @db.Uuid
  gateway       PaymentGateway @default(MERCADO_PAGO)
  transactionId String?        @unique @map("transaction_id")
  amount        Decimal        @db.Decimal(10, 2)
  status        PaymentStatus  @default(PENDING)
  qrCode        String?        @map("qr_code")
  receiptUrl    String?        @map("receipt_url")
  paidAt        DateTime?      @map("paid_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  league League @relation(fields: [leagueId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([leagueId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Notification {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  title           String           @db.VarChar(200)
  body            String
  message         String?
  type            NotificationType @default(INFO)
  readAt          DateTime?        @map("read_at")
  isRead          Boolean          @default(false) @map("is_read")
  xpReceived      Int?             @map("xp_received")
  levelAfter      Int?             @map("level_after")
  relatedEntityId String?          @map("related_entity_id") @db.VarChar(180)
  uniqueKey       String?          @unique @map("unique_key") @db.VarChar(220)
  icon            String?          @db.VarChar(40)
  createdAt       DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, type, createdAt], map: "notifications_user_type_created_at_idx")
  @@index([userId, isRead], map: "notifications_user_is_read_idx")
  @@map("notifications")
}

model Badge {
  id          String      @id @default(uuid()) @db.Uuid
  key         String?     @unique @db.VarChar(80)
  title       String      @db.VarChar(100)
  description String
  image       String?
  rarity      BadgeRarity @default(COMMON)
  createdAt   DateTime    @default(now()) @map("created_at")

  achievements Achievement[]

  @@unique([title])
  @@index([rarity])
  @@map("badges")
}

model Achievement {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  badgeId    String   @map("badge_id") @db.Uuid
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Restrict)

  @@unique([userId, badgeId])
  @@index([badgeId])
  @@map("achievements")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(120)
  entity    String   @db.VarChar(120)
  entityId  String?  @map("entity_id") @db.VarChar(80)
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ip        String?  @db.VarChar(80)
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(120)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model FootballSyncLog {
  id                String    @id @default(uuid()) @db.Uuid
  competitionKey    String    @map("competition_key") @db.VarChar(80)
  leagueId          Int       @map("league_id")
  season            Int
  status            String    @db.VarChar(20)
  message           String?
  callsUsed         Int       @default(0) @map("calls_used")
  teamsImported     Int       @default(0) @map("teams_imported")
  roundsImported    Int       @default(0) @map("rounds_imported")
  matchesImported   Int       @default(0) @map("matches_imported")
  standingsImported Int       @default(0) @map("standings_imported")
  startedAt         DateTime  @default(now()) @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  createdAt         DateTime  @default(now()) @map("created_at")

