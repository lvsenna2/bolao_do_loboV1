}

model FootballSyncLock {
  key         String   @id @db.VarChar(80)
  ownerToken  String   @map("owner_token") @db.VarChar(80)
  lockedUntil DateTime @map("locked_until")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([lockedUntil])
  @@map("football_sync_locks")
}

model FootballAutomationLog {
  id                  String    @id @default(uuid()) @db.Uuid
  runId               String    @unique @map("run_id") @db.VarChar(80)
  trigger             String    @db.VarChar(30)
  status              String    @db.VarChar(20)
  callsUsed           Int       @default(0) @map("calls_used")
  trackedMatches      Int       @default(0) @map("tracked_matches")
  liveMatches         Int       @default(0) @map("live_matches")
  pendingLineups      Int       @default(0) @map("pending_lineups")
  pendingFinalDetails Int       @default(0) @map("pending_final_details")
  message             String?
  error               String?
  startedAt           DateTime  @default(now()) @map("started_at")
  finishedAt          DateTime? @map("finished_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([createdAt])
  @@map("football_automation_logs")
}

model CompetitionStanding {
  id           String   @id @default(uuid()) @db.Uuid
  seasonId     String   @map("season_id") @db.Uuid
  teamId       String   @map("team_id") @db.Uuid
  groupName    String   @default("Geral") @map("group_name") @db.VarChar(120)
  rank         Int
  points       Int      @default(0)
  played       Int      @default(0)
  wins         Int      @default(0)
  draws        Int      @default(0)
  losses       Int      @default(0)
  goalsFor     Int      @default(0) @map("goals_for")
  goalsAgainst Int      @default(0) @map("goals_against")
  goalDiff     Int      @default(0) @map("goal_diff")
  form         String?  @db.VarChar(30)
  status       String?  @db.VarChar(80)
  description  String?
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@unique([seasonId, teamId, groupName])
  @@index([seasonId, rank])
  @@index([teamId])
  @@map("competition_standings")
}
